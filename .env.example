APP_NAME=KARYA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database: PostgreSQL 16 (primary target) --------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=karya
DB_USERNAME=karya
DB_PASSWORD=secret

# --- Queue / cache -----------------------------------------------------------
# Standard (4GB+) profile: redis. Minimal (2GB) profile: set both to database/file.
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- KARYA product knobs -----------------------------------------------------
KARYA_PROFILE=standard
KARYA_PPN_RATE=11
KARYA_EFAKTUR_CHANNEL=file
